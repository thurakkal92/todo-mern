{
  "name": "@todo/backend",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@todo/shared": "*",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "mongoose": "8.23.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/node": "22.10.5",
    "@types/supertest": "6.0.2",
    "mongodb-memory-server": "10.1.4",
    "supertest": "7.1.3",
    "tsx": "4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
